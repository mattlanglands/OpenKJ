FROM debian:12

ENV DEBIAN_FRONTEND='noninteractive'

RUN apt-get -qq update && \
	apt-get -qq -y upgrade && \
	apt-get -qq -y install \
	cmake \
	ninja-build \
	qt6-base-dev \
	qt6-svg-dev \
	qt6-webengine-dev \
	libgstreamer1.0-dev \
	libtagc0-dev \
	libspdlog-dev \
	libgstreamer-plugins-base1.0-dev \
	&& \
	rm -rf /var/cache/apt/*

COPY ./ /openkj/
WORKDIR /openkj/
RUN cmake -DSPDLOG_USE_BUNDLED=true . -B build -G Ninja
RUN ninja -C build
